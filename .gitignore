# Build
/build/
*.o
*.a
*.dylib
*.so

# Models (large) — runtime files in mumodel/, unused pre-conversion originals in orgmodel/
/models/*
!/models/.gitkeep
/mumodel/*
!/mumodel/README.md
/orgmodel/

# Editor / OS
.DS_Store
.vscode/
.idea/
compile_commands.json

# Test output
/tests/out/

# Reference source clones (large, own licenses) — fetch via scripts/fetch_reference.sh
/third_party/reference/

# pdfium prebuilt binary (large) — fetch via scripts/fetch_pdfium.sh
/third_party/pdfium/

# CLI output
/output/

# PDFs (test inputs / scratch) — not tracked; fixtures are fetched/placed locally
*.pdf

# Vendored MLX runtime (large) — fetch via scripts/fetch_mlx.sh
/third_party/mlx/

# Vendored ONNX Runtime (fetch via scripts/fetch_onnxruntime.sh)
/third_party/onnxruntime/

# Static OpenCV built from source (scripts/build_opencv_static.sh)
/third_party/opencv/
/third_party/.opencv-src/
/third_party/.opencv-build/

# Static MLX built from source (scripts/build_mlx_static.sh)
/third_party/mlx-static/
/third_party/.mlx-src/
/third_party/.mlx-build/

# Trimmed static pdfium: source clone + deps + build (scripts/build_pdfium_static_src.sh).
# The CMake build recipe (third_party/pdfium-cmake/) IS tracked; the source/artifacts are not.
/third_party/.pdfium-src/
/third_party/.pdfium-build/
/third_party/.pdfium-cmake-build/
/third_party/pdfium-static/

# Static ONNX Runtime built from source (scripts/build_onnxruntime_static.sh)
/third_party/.onnxruntime-src/
/third_party/onnxruntime-static/

# getmodel CLI built from the vendored source (scripts/fetch_mumodel.sh). The source under
# third_party/getmodel/ IS tracked; the built binary is not.
/third_party/.getmodel-bin/

# Static MNN built from source (scripts/build_mnn_static.sh; optional hybrid pipeline accel)
/third_party/.mnn-src/
/third_party/mnn-static/

# Large generated layout test input (regenerated by gen_pp_layout_golden.py)
/tests/golden/layout_input.rgb
/tests/golden/ocr_rec_input.rgb

# web UI (built/generated)
web/node_modules/
web/dist/
src/cli/web_assets.gen.cpp
