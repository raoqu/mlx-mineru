# Build
/build/
*.o
*.a
*.dylib
*.so

# Models (downloaded at runtime, large)
/models/*
!/models/.gitkeep

# Editor / OS
.DS_Store
.vscode/
.idea/
compile_commands.json

# Test output
/tests/out/

# Reference source clones (large, own licenses) — fetch via scripts/fetch_reference.sh
/third_party/reference/

# pdfium prebuilt binary (large) — fetch via scripts/fetch_pdfium.sh
/third_party/pdfium/

# CLI output
/output/

# Vendored MLX runtime (large) — fetch via scripts/fetch_mlx.sh
/third_party/mlx/

# Vendored ONNX Runtime (fetch via scripts/fetch_onnxruntime.sh)
/third_party/onnxruntime/

# Large generated layout test input (regenerated by gen_pp_layout_golden.py)
/tests/golden/layout_input.rgb
/tests/golden/ocr_rec_input.rgb

# web UI (built/generated)
web/node_modules/
web/dist/
src/cli/web_assets.gen.cpp
